# Port the server listens on (most hosts set this for you automatically)
PORT=3001

# The public HTTPS URL where this app will be reachable once deployed.
# MUST match exactly (no trailing slash) — it's used as the OAuth redirect_uri.
# For local testing: http://localhost:3001
PUBLIC_URL=https://your-app.example.com

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# This is separate/pay-as-you-go billing, not your claude.ai subscription.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Password to protect the app (leave empty to disable — not recommended
# once it's on a public URL).
APP_PASSWORD=change-me

NODE_ENV=production
